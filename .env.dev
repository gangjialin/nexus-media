# ==================== 数据库 ====================
DB_USER=nexus
DB_PASSWORD=dev_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus_media

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==================== RabbitMQ ====================
RABBITMQ_USER=nexus
RABBITMQ_PASSWORD=dev_password
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# ==================== MinIO (对象存储) ====================
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=nexus-proxy
MINIO_USE_SSL=false

# ==================== 文件存储 ====================
# 开发环境用本地目录，生产环境改为 NFS 挂载路径
NAS_MOUNT_PATH=./dev-storage/assets

# ==================== JWT ====================
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== 应用配置 ====================
APP_NAME=Nexus Media
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG

# ==================== CORS ====================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8000"]

# ==================== 通知推送（可选） ====================
# WECOM_WEBHOOK_URL=
# FEISHU_WEBHOOK_URL=

# ==================== AI 服务（可选） ====================
# OPENAI_API_KEY=
# DASHSCOPE_API_KEY=  # 通义千问
